#!/bin/sh

NIRI_CONFIG="$HOME/.config/niri/"
WAYBAR_CONFIG="$HOME/.config/waybar/"
NIRI_LAYOUT_SYMLINK=$NIRI_CONFIG"layout.kdl"
NIRI_LAYOUT_0=$NIRI_CONFIG"layout0.kdl"
NIRI_LAYOUT_16=$NIRI_CONFIG"layout16.kdl"

WAYBAR_SYMLINK=$WAYBAR_CONFIG"style.css"
WAYBAR_0=$WAYBAR_CONFIG"style0.css"
WAYBAR_16=$WAYBAR_CONFIG"style16.css"
LINK="$(readlink "$NIRI_LAYOUT_SYMLINK")"
if [ "${LINK}" = "${NIRI_LAYOUT_16}" ]; then
  ln -sf "$NIRI_LAYOUT_0" "$NIRI_LAYOUT_SYMLINK";
  ln -sf "$WAYBAR_0" "$WAYBAR_SYMLINK"
  pkill -USR2 "waybar"
else
  ln -sf "$NIRI_LAYOUT_16" "$NIRI_LAYOUT_SYMLINK";
  ln -sf "$WAYBAR_16" "$WAYBAR_SYMLINK"
  pkill -USR2 "waybar"
fi

